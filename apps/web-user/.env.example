# ==============================================================================
# Safaar — Web User Environment Variables Configuration (.env.example)
# Copy this file to `.env.local` and fill in your actual values.
# ==============================================================================

# 1. API SERVER & BACKEND ENDPOINT
# Backend API base URL (Backend API uses `v1` prefix e.g. http://localhost:4000/v1)
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# 2. SITE & CANONICAL DOMAIN
# Public domain URL used for SEO, OpenGraph metadata, Sitemap, and canonical tags
NEXT_PUBLIC_SITE_URL=https://safaar.uz

# 3. AUTHENTICATION & OAUTH PROVIDERS
# Google OAuth Client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Telegram Auth Bot Username
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# 4. PAYMENT GATEWAYS (Public Merchant IDs)
# Click Merchant Service ID
NEXT_PUBLIC_CLICK_SERVICE_ID=

# Payme Merchant ID
NEXT_PUBLIC_PAYME_MERCHANT_ID=

# 5. ANALYTICS & MONITORING (Optional)
# Google Analytics Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Sentry DSN for frontend error reporting
NEXT_PUBLIC_SENTRY_DSN=
