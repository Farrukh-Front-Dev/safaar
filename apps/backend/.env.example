NODE_ENV=development
APP_NAME=uzbron-api
PORT=4000
API_PREFIX=v1
APP_URL=http://localhost:4000
PUBLIC_API_ORIGIN=http://localhost:4000
UPLOADS_DIR=./uploads
BUSINESS_TIMEZONE=Asia/Tashkent

DATABASE_URL=postgresql://uzbron:uzbron@localhost:5432/uzbron
REDIS_URL=redis://localhost:6379/0
QUEUE_REDIS_URL=redis://localhost:6379/1
DB_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=5000
DB_QUERY_ATTEMPTS=1
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=10000
SLOW_REQUEST_MS=1000
SLOW_QUERY_MS=300
CACHE_ENABLED=true
CACHE_DEFAULT_TTL_SECONDS=300

JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=uzbron-api
JWT_AUDIENCE=uzbron-clients
OTP_PEPPER=change_me_min_32_chars
TOTP_ENCRYPTION_KEY=change_me_min_32_chars
RECOVERY_CODE_PEPPER=change_me_min_32_chars
PARTNER_API_KEY_PEPPER=change_me_min_32_chars
PAYMENT_WEBHOOK_SECRET=change_me_min_32_chars

# Development local demo uchun true bo'lishi mumkin.
# Productionda hammasi false bo'lishi shart.
ENABLE_DEMO_AUTH=true
ENABLE_IN_MEMORY_DATA=false
ENABLE_MOCK_PAYMENTS=true

GOOGLE_CLIENT_ID=change_me
GOOGLE_CLIENT_SECRET=change_me
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
FACEBOOK_APP_ID=change_me
FACEBOOK_APP_SECRET=change_me
FACEBOOK_CALLBACK_URL=http://localhost:4000/v1/auth/facebook/callback

SMS_PROVIDER=eskiz
ESKIZ_EMAIL=change_me
ESKIZ_PASSWORD=change_me
ESKIZ_FROM=UzBron

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@uzbron.uz
SMTP_PASS=change_me
SMTP_FROM=UzBron.uz <noreply@uzbron.uz>

CLICK_SERVICE_ID=change_me
CLICK_MERCHANT_ID=change_me
CLICK_SECRET_KEY=change_me
PAYME_MERCHANT_ID=change_me
PAYME_KEY=change_me
UZCARD_MERCHANT_ID=change_me
UZCARD_SECRET_KEY=change_me
HUMO_MERCHANT_ID=change_me
HUMO_SECRET_KEY=change_me

CASH_PAYMENT_ENABLED=false
PARTNER_API_ENABLED=false
PARTNER_API_DEFAULT_RATE_LIMIT=60
PARTNER_WEBHOOK_SIGNING_SECRET=change_me

STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=local
STORAGE_BUCKET_PUBLIC=uzbron-public
STORAGE_BUCKET_PRIVATE=uzbron-private
STORAGE_ACCESS_KEY_ID=change_me
STORAGE_SECRET_ACCESS_KEY=change_me
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/uzbron-public

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
SWAGGER_ENABLED=true
