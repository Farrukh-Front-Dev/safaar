generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  uz
  ru
  en
}

enum UserStatus {
  unverified
  active
  blocked
  deleted
}

enum PartnerOrganizationType {
  hotel
  bus
  mixed
}

enum PartnerStatus {
  draft
  submitted
  under_review
  more_information_required
  approved
  suspended
  rejected
  blocked
}

enum HotelStatus {
  draft
  pending_review
  published
  hidden
  rejected
}

enum RoomStatus {
  active
  inactive
}

enum TripStatus {
  scheduled
  cancelled
  completed
}

enum TripSeatStatus {
  available
  held
  booked
  blocked
}

enum BookingType {
  hotel
  bus
}

enum ConfirmationMode {
  instant_confirmation
  request_confirmation
}

enum PaymentMethod {
  click
  payme
  uzcard
  humo
  cash
}

enum BookingStatus {
  pending
  awaiting_payment
  awaiting_partner_confirmation
  confirmed
  cancelled
  completed
  expired
}

enum PaymentStatus {
  pending
  awaiting_cash
  processing
  paid
  failed
  refunded
}

enum RefundStatus {
  requested
  approved
  rejected
  processing
  paid
}

enum ReviewStatus {
  published
  hidden
  pending_review
}

model User {
  id                String        @id @default(uuid()) @db.Uuid
  firstName         String?       @map("first_name") @db.VarChar(100)
  lastName          String?       @map("last_name") @db.VarChar(100)
  phone             String        @unique @db.VarChar(20)
  email             String?       @unique @db.VarChar(255)
  status            UserStatus    @default(unverified)
  preferredLanguage Language      @default(uz) @map("preferred_language")
  blockedReason     String?       @map("blocked_reason")
  phoneVerifiedAt   DateTime?     @map("phone_verified_at") @db.Timestamptz
  lastLoginAt       DateTime?     @map("last_login_at") @db.Timestamptz
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?     @map("deleted_at") @db.Timestamptz

  socialAccounts UserSocialAccount[]
  sessions       AuthSession[]
  bookings       Booking[]
  favorites      Favorite[]
  reviews        Review[]
  notifications  Notification[]
  supportTickets SupportTicket[]

  @@index([status, createdAt])
  @@index([deletedAt, createdAt])
  @@map("users")
}

model UserSocialAccount {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String   @db.VarChar(32)
  providerUserId String   @map("provider_user_id") @db.VarChar(255)
  providerEmail  String?  @map("provider_email") @db.VarChar(255)
  emailVerified  Boolean  @default(false) @map("email_verified")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@map("user_social_accounts")
}

model AuthSession {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  actorType    String    @map("actor_type") @db.VarChar(32)
  actorId      String    @map("actor_id") @db.Uuid
  refreshHash  String    @map("refresh_hash") @db.VarChar(255)
  refreshJti   String?   @map("refresh_jti") @db.VarChar(128)
  familyId     String    @map("family_id") @db.Uuid
  replacedByJti String?  @map("replaced_by_jti") @db.VarChar(128)
  ipAddress    String?   @map("ip_address") @db.VarChar(64)
  userAgent    String?   @map("user_agent")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  lastUsedAt   DateTime? @map("last_used_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([actorType, actorId])
  @@index([familyId])
  @@map("auth_sessions")
}

model OtpChallenge {
  id           String    @id @default(uuid()) @db.Uuid
  phone        String    @db.VarChar(20)
  purpose      String    @db.VarChar(40)
  codeHash     String    @map("code_hash") @db.VarChar(255)
  attempts     Int       @default(0)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  consumedAt   DateTime? @map("consumed_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([phone, purpose, expiresAt])
  @@map("otp_challenges")
}

model PartnerOrganization {
  id                    String                  @id @default(uuid()) @db.Uuid
  type                  PartnerOrganizationType
  legalName             String                  @map("legal_name") @db.VarChar(255)
  brandName             String                  @map("brand_name") @db.VarChar(255)
  taxId                 String?                 @unique @map("tax_id") @db.VarChar(32)
  phone                 String                  @db.VarChar(20)
  email                 String                  @db.VarChar(255)
  cityId                String                  @map("city_id") @db.Uuid
  address               String?
  status                PartnerStatus           @default(draft)
  defaultCommissionRate Decimal                 @default(12.00) @map("default_commission_rate") @db.Decimal(5, 2)
  approvedBy            String?                 @map("approved_by") @db.Uuid
  approvedAt            DateTime?               @map("approved_at") @db.Timestamptz
  rejectionReason       String?                 @map("rejection_reason")
  createdAt             DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  city          City          @relation(fields: [cityId], references: [id])
  partnerUsers  PartnerUser[]
  hotels        Hotel[]
  busCompanies  BusCompany[]
  bookings      Booking[]
  apiKeys       PartnerApiKey[]
  webhooks      PartnerWebhookEndpoint[]
  ledgerEntries PartnerLedgerEntry[]

  @@index([status])
  @@index([cityId, status])
  @@index([status, createdAt])
  @@map("partner_organizations")
}

model PartnerUser {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String    @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  fullName       String?   @map("full_name") @db.VarChar(255)
  status         String    @default("active") @db.VarChar(32)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  organization PartnerOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([email])
  @@map("partner_users")
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String?   @map("full_name") @db.VarChar(255)
  role         String    @db.VarChar(64)
  status       String    @default("active") @db.VarChar(32)
  totpSecret   String?   @map("totp_secret") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz

  recoveryCodes AdminRecoveryCode[]

  @@index([deletedAt, createdAt])
  @@map("admin_users")
}

model AdminRecoveryCode {
  id        String    @id @default(uuid()) @db.Uuid
  adminId   String    @map("admin_id") @db.Uuid
  codeHash  String    @map("code_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, usedAt])
  @@map("admin_recovery_codes")
}

model Region {
  id        String   @id @default(uuid()) @db.Uuid
  name      Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cities City[]

  @@map("regions")
}

model City {
  id        String   @id @default(uuid()) @db.Uuid
  regionId  String   @map("region_id") @db.Uuid
  name      Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  region       Region                @relation(fields: [regionId], references: [id])
  partners     PartnerOrganization[]
  hotels       Hotel[]
  routesFrom   Route[]               @relation("RouteFromCity")
  routesTo     Route[]               @relation("RouteToCity")
  tripsFrom    Trip[]                @relation("TripFromCity")
  tripsTo      Trip[]                @relation("TripToCity")

  @@index([regionId])
  @@map("cities")
}

model Amenity {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(80)
  name      Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hotelLinks HotelAmenity[]
  roomLinks  RoomAmenity[]

  @@map("amenities")
}

model RoomType {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(80)
  name      Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  rooms HotelRoom[]

  @@map("room_types")
}

model MediaFile {
  id          String    @id @default(uuid()) @db.Uuid
  ownerType   String    @map("owner_type") @db.VarChar(32)
  ownerId     String    @map("owner_id") @db.Uuid
  bucket      String    @db.VarChar(100)
  objectKey   String    @map("object_key")
  url         String?
  mimeType    String    @map("mime_type") @db.VarChar(120)
  size        Int
  visibility  String    @default("private") @db.VarChar(32)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  @@index([ownerType, ownerId])
  @@map("media_files")
}

model CancellationPolicy {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  Json
  rules                 Json
  refundableUntilHours  Int?     @map("refundable_until_hours")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hotels Hotel[]

  @@map("cancellation_policies")
}

model Hotel {
  id                    String      @id @default(uuid()) @db.Uuid
  partnerOrganizationId String      @map("partner_organization_id") @db.Uuid
  slug                  String      @unique @db.VarChar(255)
  cityId                String      @map("city_id") @db.Uuid
  address               String
  latitude              Decimal?    @db.Decimal(10, 7)
  longitude             Decimal?    @db.Decimal(10, 7)
  stars                 Int
  ratingAverage         Decimal     @default(0) @map("rating_average") @db.Decimal(3, 2)
  reviewsCount          Int         @default(0) @map("reviews_count")
  status                HotelStatus @default(draft)
  checkInTime           String?     @map("check_in_time") @db.VarChar(5)
  checkOutTime          String?     @map("check_out_time") @db.VarChar(5)
  cancellationPolicyId  String?     @map("cancellation_policy_id") @db.Uuid
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?   @map("deleted_at") @db.Timestamptz

  partner           PartnerOrganization @relation(fields: [partnerOrganizationId], references: [id])
  city              City                @relation(fields: [cityId], references: [id])
  cancellationPolicy CancellationPolicy? @relation(fields: [cancellationPolicyId], references: [id])
  translations      HotelTranslation[]
  amenities         HotelAmenity[]
  rooms             HotelRoom[]
  bookings          Booking[]

  @@index([cityId, status])
  @@index([ratingAverage])
  @@index([partnerOrganizationId, status])
  @@index([status, createdAt])
  @@index([status, ratingAverage])
  @@index([status, stars])
  @@map("hotels")
}

model HotelTranslation {
  id          String   @id @default(uuid()) @db.Uuid
  hotelId     String   @map("hotel_id") @db.Uuid
  language    Language
  name        String   @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  hotel Hotel @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@unique([hotelId, language])
  @@map("hotel_translations")
}

model HotelAmenity {
  hotelId   String @map("hotel_id") @db.Uuid
  amenityId String @map("amenity_id") @db.Uuid

  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([hotelId, amenityId])
  @@map("hotel_amenities")
}

model HotelRoom {
  id             String     @id @default(uuid()) @db.Uuid
  hotelId        String     @map("hotel_id") @db.Uuid
  roomTypeId     String     @map("room_type_id") @db.Uuid
  code           String     @db.VarChar(50)
  baseOccupancy  Int        @map("base_occupancy")
  maxAdults      Int        @map("max_adults")
  maxChildren    Int        @map("max_children")
  totalInventory Int        @map("total_inventory")
  basePrice      Decimal    @map("base_price") @db.Decimal(18, 2)
  status         RoomStatus @default(active)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  hotel        Hotel                  @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  roomType     RoomType               @relation(fields: [roomTypeId], references: [id])
  translations HotelRoomTranslation[]
  amenities    RoomAmenity[]
  inventory    RoomInventory[]

  @@unique([hotelId, code])
  @@index([hotelId, status])
  @@map("hotel_rooms")
}

model HotelRoomTranslation {
  id          String   @id @default(uuid()) @db.Uuid
  roomId      String   @map("room_id") @db.Uuid
  language    Language
  name        String   @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  room HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, language])
  @@map("hotel_room_translations")
}

model RoomAmenity {
  roomId    String @map("room_id") @db.Uuid
  amenityId String @map("amenity_id") @db.Uuid

  room    HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  amenity Amenity   @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([roomId, amenityId])
  @@map("room_amenities")
}

model RoomInventory {
  id          String   @id @default(uuid()) @db.Uuid
  roomId      String   @map("room_id") @db.Uuid
  date        DateTime @db.Date
  totalCount  Int      @map("total_count")
  heldCount   Int      @default(0) @map("held_count")
  bookedCount Int      @default(0) @map("booked_count")
  closed      Boolean  @default(false)
  version     Int      @default(1)

  room HotelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@index([date])
  @@map("room_inventory")
}

model BusCompany {
  id                    String   @id @default(uuid()) @db.Uuid
  partnerOrganizationId String   @map("partner_organization_id") @db.Uuid
  name                  String   @db.VarChar(255)
  status                String   @default("active") @db.VarChar(32)
  ratingAverage         Decimal  @default(0) @map("rating_average") @db.Decimal(3, 2)
  reviewsCount          Int      @default(0) @map("reviews_count")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  partner  PartnerOrganization @relation(fields: [partnerOrganizationId], references: [id])
  vehicles Vehicle[]
  trips    Trip[]

  @@index([partnerOrganizationId, status])
  @@index([status, createdAt])
  @@map("bus_companies")
}

model Vehicle {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  name         String   @db.VarChar(255)
  plateNumber  String?  @map("plate_number") @db.VarChar(32)
  seatsCount   Int      @map("seats_count")
  seatLayout   Json?    @map("seat_layout")
  status       String   @default("active") @db.VarChar(32)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  company BusCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  trips   Trip[]

  @@index([companyId, status])
  @@map("vehicles")
}

model Route {
  id              String   @id @default(uuid()) @db.Uuid
  fromCityId      String   @map("from_city_id") @db.Uuid
  toCityId        String   @map("to_city_id") @db.Uuid
  durationMinutes Int      @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  fromCity City  @relation("RouteFromCity", fields: [fromCityId], references: [id])
  toCity   City  @relation("RouteToCity", fields: [toCityId], references: [id])
  trips    Trip[]

  @@index([fromCityId, toCityId])
  @@map("routes")
}

model Trip {
  id            String     @id @default(uuid()) @db.Uuid
  routeId       String     @map("route_id") @db.Uuid
  companyId     String     @map("company_id") @db.Uuid
  vehicleId     String?    @map("vehicle_id") @db.Uuid
  fromCityId    String     @map("from_city_id") @db.Uuid
  toCityId      String     @map("to_city_id") @db.Uuid
  departureAt   DateTime   @map("departure_at") @db.Timestamptz
  arrivalAt     DateTime   @map("arrival_at") @db.Timestamptz
  status        TripStatus @default(scheduled)
  basePrice     Decimal    @map("base_price") @db.Decimal(18, 2)
  policySnapshot Json?     @map("policy_snapshot")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  route    Route      @relation(fields: [routeId], references: [id])
  company  BusCompany @relation(fields: [companyId], references: [id])
  vehicle  Vehicle?   @relation(fields: [vehicleId], references: [id])
  fromCity City       @relation("TripFromCity", fields: [fromCityId], references: [id])
  toCity   City       @relation("TripToCity", fields: [toCityId], references: [id])
  seats    TripSeat[]
  bookings Booking[]

  @@index([fromCityId, toCityId, departureAt])
  @@index([status, departureAt])
  @@index([routeId, departureAt, status])
  @@index([companyId, status, departureAt])
  @@map("trips")
}

model TripSeat {
  id                String         @id @default(uuid()) @db.Uuid
  tripId            String         @map("trip_id") @db.Uuid
  seatCode          String         @map("seat_code") @db.VarChar(10)
  seatClass         String         @default("standard") @map("seat_class") @db.VarChar(32)
  price             Decimal        @db.Decimal(18, 2)
  status            TripSeatStatus @default(available)
  heldByBookingId   String?        @map("held_by_booking_id") @db.Uuid
  heldUntil         DateTime?      @map("held_until") @db.Timestamptz

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, seatCode])
  @@index([status])
  @@index([tripId, status])
  @@map("trip_seats")
}

model Booking {
  id                          String            @id @default(uuid()) @db.Uuid
  bookingNumber               String            @unique @map("booking_number") @db.VarChar(30)
  userId                      String            @map("user_id") @db.Uuid
  partnerOrganizationId       String            @map("partner_organization_id") @db.Uuid
  type                        BookingType
  confirmationMode            ConfirmationMode  @map("confirmation_mode")
  paymentMethod               PaymentMethod     @map("payment_method")
  status                      BookingStatus     @default(pending)
  currency                    String            @default("UZS") @db.Char(3)
  subtotal                    Decimal           @db.Decimal(18, 2)
  discountAmount              Decimal           @default(0) @map("discount_amount") @db.Decimal(18, 2)
  bonusAmount                 Decimal           @default(0) @map("bonus_amount") @db.Decimal(18, 2)
  serviceFee                  Decimal           @default(0) @map("service_fee") @db.Decimal(18, 2)
  totalAmount                 Decimal           @map("total_amount") @db.Decimal(18, 2)
  commissionAmount            Decimal           @map("commission_amount") @db.Decimal(18, 2)
  partnerPayable              Decimal           @map("partner_payable") @db.Decimal(18, 2)
  hotelId                     String?           @map("hotel_id") @db.Uuid
  tripId                      String?           @map("trip_id") @db.Uuid
  partnerConfirmationDeadline DateTime?         @map("partner_confirmation_deadline") @db.Timestamptz
  expiresAt                   DateTime?         @map("expires_at") @db.Timestamptz
  confirmedAt                 DateTime?         @map("confirmed_at") @db.Timestamptz
  cancelledAt                 DateTime?         @map("cancelled_at") @db.Timestamptz
  cancelReasonText            String?           @map("cancel_reason_text")
  policySnapshot              Json              @map("policy_snapshot")
  priceSnapshot               Json              @map("price_snapshot")
  createdAt                   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user         User                @relation(fields: [userId], references: [id])
  partner      PartnerOrganization @relation(fields: [partnerOrganizationId], references: [id])
  hotel        Hotel?              @relation(fields: [hotelId], references: [id])
  trip         Trip?               @relation(fields: [tripId], references: [id])
  history      BookingStatusHistory[]
  payments     Payment[]
  refunds      Refund[]
  messages     BookingMessage[]
  ledgerEntries PartnerLedgerEntry[]

  @@index([userId, createdAt])
  @@index([partnerOrganizationId, status])
  @@index([partnerOrganizationId, createdAt])
  @@index([status, createdAt])
  @@index([status, expiresAt])
  @@index([type, status, createdAt])
  @@index([hotelId, createdAt])
  @@index([tripId, createdAt])
  @@map("bookings")
}

model BookingStatusHistory {
  id        String        @id @default(uuid()) @db.Uuid
  bookingId String        @map("booking_id") @db.Uuid
  status    BookingStatus
  action    String        @db.VarChar(80)
  actorType String?       @map("actor_type") @db.VarChar(32)
  actorId   String?       @map("actor_id") @db.Uuid
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

