#!/usr/bin/env bash
#
# UzBron pre-push guard — "o'z papkangdan tashqariga tegma".
#
# Maqsad: har bir dev faqat CODEOWNERS'da o'ziga tegishli papka(lar)ni
# o'zgartirsin. Agar push qilinayotgan commitlaringizda (faqat SIZNING
# muallifligingizdagi, merge bo'lmagan commitlar) ruxsatsiz papkadagi fayl
# o'zgargan bo'lsa — push to'xtaydi.
#
# Tekshirilmaydi (ataylab):
#   - merge commitlar (integratsiya: develop->main, partner->develop, ...)
#   - boshqa odam muallifligidagi commitlar (siz faqat tortib olyapsiz)
#   - umumiy avto-generatsiya fayllari (pastdagi SHARED_ALLOW ro'yxati)
#
# Vaqtinchalik chetlab o'tish (zarur bo'lsa, ataylab boshqa papkaga tegganda):
#   HOOK_ALLOW_CROSS_FOLDER=1 git push
#   yoki:  git config hooks.allowCrossFolder true
#
set -euo pipefail

ZERO="0000000000000000000000000000000000000000"

# --- 0) Chetlab o'tish bayrog'i ---
if [ "${HOOK_ALLOW_CROSS_FOLDER:-0}" = "1" ] \
   || [ "$(git config --bool hooks.allowCrossFolder 2>/dev/null || echo false)" = "true" ]; then
  echo "pre-push: cross-folder tekshiruvi chetlab o'tildi (HOOK_ALLOW_CROSS_FOLDER)."
  exit 0
fi

# --- 1) Repo root va CODEOWNERS ---
ROOT="$(git rev-parse --show-toplevel)"
CODEOWNERS=""
for c in "$ROOT/CODEOWNERS" "$ROOT/.github/CODEOWNERS" "$ROOT/docs/CODEOWNERS"; do
  [ -f "$c" ] && CODEOWNERS="$c" && break
done
if [ -z "$CODEOWNERS" ]; then
  echo "pre-push: CODEOWNERS topilmadi — tekshiruv o'tkazib yuborildi."
  exit 0
fi

# --- 2) Joriy foydalanuvchi ---
USER_NAME="$(git config user.name || true)"
if [ -z "$USER_NAME" ]; then
  echo "pre-push: git user.name sozlanmagan — tekshiruv o'tkazib yuborildi."
  exit 0
fi

# --- 3) Shu userga tegishli yo'l-prefikslarni CODEOWNERS'dan yig'ish ---
# Har qator:  <pattern>  <@owner1> [@owner2 ...]
OWNED="$(awk -v u="@$USER_NAME" '
  /^[[:space:]]*#/ {next}
  /^[[:space:]]*$/ {next}
  {
    pat=$1
    for (i=2; i<=NF; i++) {
      if ($i == u) { sub(/^\//,"",pat); print pat; break }
    }
  }' "$CODEOWNERS")"

if [ -z "$OWNED" ]; then
  echo "pre-push: '$USER_NAME' uchun CODEOWNERS'da papka topilmadi — tekshiruv o'tkazib yuborildi."
  exit 0
fi

# Umumiy, hammaga ruxsat etilgan fayllar (avto-generatsiya / lock)
SHARED_ALLOW="package-lock.json"

# Fayl ruxsat etilganmi? (owned prefiks yoki shared)
is_allowed() {
  local f="$1" p
  for p in $SHARED_ALLOW; do
    [ "$f" = "$p" ] && return 0
  done
  for p in $OWNED; do
    case "$p" in
      */) [ "${f#$p}" != "$f" ] && return 0 ;;   # papka prefiksi
      *)  [ "$f" = "$p" ] && return 0 ;;          # aniq fayl
    esac
  done
  return 1
}

VIOLATIONS=0

# --- 4) Push qilinayotgan har bir ref bo'yicha o'tish (stdin protokoli) ---
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue   # branch o'chirilyapti — o'tkazib yubor

  if [ "$remote_sha" = "$ZERO" ]; then
    # Yangi branch: origin default'ga nisbatan
    base="$(git rev-parse --verify --quiet origin/develop || git rev-parse --verify --quiet origin/main || true)"
    range="${base:+$base..}$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # Faqat SIZNING muallifligingizdagi, merge BO'LMAGAN commitlar
  commits="$(git log --no-merges --author="$USER_NAME" --format='%H' "$range" 2>/dev/null || true)"
  [ -z "$commits" ] && continue

  for sha in $commits; do
    files="$(git diff-tree --no-commit-id --name-only -r "$sha" 2>/dev/null || true)"
    for f in $files; do
      if ! is_allowed "$f"; then
        if [ "$VIOLATIONS" -eq 0 ]; then
          echo ""
          echo "⛔ pre-push TO'XTATILDI — o'z papkangizdan tashqaridagi fayl o'zgartirilgan:"
          echo "   Dev: $USER_NAME | Ruxsat etilgan: $(echo $OWNED | tr '\n' ' ')"
          echo ""
        fi
        echo "   • $f   (commit ${sha:0:8})"
        VIOLATIONS=$((VIOLATIONS+1))
      fi
    done
  done
done

if [ "$VIOLATIONS" -gt 0 ]; then
  echo ""
  echo "Jami $VIOLATIONS ta ruxsatsiz o'zgarish. Variantlar:"
  echo "  1) O'zgarishni o'z papkangizga qaytaring (tavsiya etiladi)."
  echo "  2) Haqiqatan kerak bo'lsa — papka egasi bilan kelishib, chetlab o'ting:"
  echo "       HOOK_ALLOW_CROSS_FOLDER=1 git push"
  echo ""
  exit 1
fi

exit 0
