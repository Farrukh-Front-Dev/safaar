{
  "name": "safaar-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "build:types": "npm run build -w @safaar/types",
    "dev:types": "npm run dev -w @safaar/types",
    "dev:backend": "npm run start:dev -w @safaar/backend",
    "dev:user": "npm run dev -w @safaar/web-user",
    "dev:partner": "npm run dev -w @safaar/web-partner",
    "dev:admin": "npm run dev -w @safaar/web-admin",
    "build": "npm run build:types && npm run build --workspaces --if-present",
    "build:backend": "npm run build -w @safaar/backend",
    "build:user": "npm run build -w @safaar/web-user",
    "build:partner": "npm run build -w @safaar/web-partner",
    "build:admin": "npm run build -w @safaar/web-admin",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm run test -w @safaar/backend",
    "format": "npm run format --workspaces --if-present"
  }
}
